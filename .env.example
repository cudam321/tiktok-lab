# Zernio API (https://docs.zernio.com)
# One API key is all you need — profiles are created automatically per account.
ZERNIO_API_KEY=sk_your_api_key_here

# AI Agent — set ONE of these (the agent is recommend-only; it never auto-posts).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AGENT_PROVIDER=auto  # "anthropic", "openai", or "auto"

# App
DATABASE_URL=sqlite+aiosqlite:///./data/tiktok_lab.db
SECRET_KEY=change-me-to-a-random-string

# OpenMontage (Phase 6 — AI content production ONLY; optional).
# Requires a separate, EXTERNAL OpenMontage install. Leave unset to disable
# content production. Point this at the root of your OpenMontage checkout.
OPENMONTAGE_PATH=
